# Django
DEBUG=False
SECRET_KEY=change-me-to-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Base de données (PostgreSQL en prod / Docker)
DATABASE_URL=postgresql://rental_user:rental_password@db:5432/rental_db

# Redis + Celery
REDIS_URL=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=False

# CORS — origines frontend autorisées (séparées par des virgules)
CORS_ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173

# URLs applicatives
FRONTEND_URL=https://your-domain.com
BACKEND_PUBLIC_URL=https://api.your-domain.com
DEFAULT_FROM_EMAIL=noreply@homify.cm

# Billing — mock en dev, Aangaraa Pay en prod
# Dev local : BILLING_MOCK_PAYMENTS=True (pas de clé API requise)
# Production : BILLING_MOCK_PAYMENTS=False + AANGARAAPAY_APP_KEY + worker Celery actif
BILLING_MOCK_PAYMENTS=True
BILLING_PAYMENT_POLL_INTERVAL_SECONDS=5
BILLING_PAYMENT_POLL_TIMEOUT_SECONDS=60
HOMIFY_FREE_PLAN_MAX_LISTINGS=2
AANGARAAPAY_APP_KEY=
AANGARAAPAY_API_BASE_URL=https://api-production.aangaraa-pay.com
AANGARAAPAY_CHECKOUT_BASE_URL=https://aangaraa-pay.com
# URL publique du backend (webhook + return notify) — ex. https://api.homify.cm
BACKEND_PUBLIC_URL=http://localhost:8000

# Email (exemple SMTP — adapter selon votre provider)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
